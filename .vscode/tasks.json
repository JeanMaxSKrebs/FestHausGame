            "label": "1 - Iniciar Metro Único (8081)",
            "type": "shell",
            "command": "npx expo start --dev-client -c --port 8081",
            "options": {
                "cwd": "C:\\FestHausGame"
            },
            "problemMatcher": [],
            "presentation": {
                "panel": "new",
                "reveal": "always",
                "clear": true
            }
